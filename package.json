{
  "name": "marked-katex-extension",
  "version": "5.1.10",
  "description": "MarkedJS extesion to render katex",
  "main": "./lib/index.cjs",
  "module": "./src/index.ts",
  "browser": "./lib/index.umd.js",
  "type": "module",
  "types": "./src/index.ts",
  "keywords": [
    "marked",
    "katex",
    "extension"
  ],
  "files": [
    "lib/",
    "src/"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./lib/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "npm run build && npm run test:katex && npm run test:spec && npm run test:types && npm run test:exports && npm run lint",
    "test:cover": "node --experimental-test-coverage ./spec/test.config.ts -- --cover",
    "test:exports": "cd spec/exports && npm install && npx tsc",
    "test:katex": "node --test ./spec/test.config.ts",
    "test:spec": "node --test ./spec/marked-tests.ts",
    "test:types": "tsd -f ./spec/index.test-d.ts -t src/index.ts",
    "lint": "eslint",
    "build": "rollup -c rollup.config.ts",
    "update-specs": "node ./update-specs.ts && node --test --test-update-snapshots ./spec/test.config.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/UziTech/marked-katex-extension.git"
  },
  "author": "Tony Brix <Tony@Brix.ninja> (https://Tony.Brix.ninja)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/UziTech/marked-katex-extension/issues"
  },
  "homepage": "https://github.com/UziTech/marked-katex-extension#readme",
  "peerDependencies": {
    "katex": ">=0.16 <0.18",
    "marked": ">=4 <19"
  },
  "devDependencies": {
    "@markedjs/eslint-config": "^1.0.14",
    "@markedjs/testutils": "18.0.5-0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/node": "^26.1.1",
    "cheerio": "^1.2.0",
    "globals": "^17.7.0",
    "jiti": "^2.7.0",
    "katex": "^0.17.0",
    "marked": "^18.0.6",
    "node-fetch": "^3.3.2",
    "rollup": "^4.62.2",
    "semantic-release": "^25.0.7",
    "tsd": "^0.33.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3"
  },
  "tsd": {
    "compilerOptions": {
      "strict": true,
      "module": "nodenext"
    }
  }
}
